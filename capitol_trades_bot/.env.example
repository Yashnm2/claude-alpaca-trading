# Alpaca credentials (already set in project root .env — no need to duplicate)
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2   # switch to https://api.alpaca.markets/v2 for live

# Bot settings
TRADE_USD_AMOUNT=500   # dollars to spend per buy trade (fractional shares supported)
